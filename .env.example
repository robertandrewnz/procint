# ══════════════════════════════════════════════════════════════════════════════
# Groundwork — Environment Variables
# Copy this file to .env for local development.
# In Railway: add each variable under Settings → Variables.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
# Railway: add a Postgres plugin → DATABASE_URL is injected automatically.
# Local: point at your local or remote Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/procint

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Required. Used for notice enrichment, pursuit packages, competitor profiles.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown)
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL_L3=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS_L3=4096

# ── Flask / Portal ────────────────────────────────────────────────────────────
# Required. Must be a long random string — used to sign session cookies.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
PORTAL_SECRET_KEY=change-this-to-a-long-random-string

# Required. Shared fallback password (used only if no client account is found).
PORTAL_PASSWORD=change-this-password

# Optional. Bind host. Default is 0.0.0.0 (required for Railway).
# PORTAL_HOST=0.0.0.0

# Optional. Port for local dev. Railway overrides this with its own PORT variable.
# PORTAL_PORT=5000

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Required for: weekly watch brief delivery, signup notifications, failure alerts.
# Gmail: use an App Password (myaccount.google.com → Security → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=robert@bidedge.co.nz
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=Groundwork by BidEdge <notifications@bidedge.co.nz>

# Email address for admin alerts (deployment failures, pipeline errors).
ADMIN_EMAIL=robert@bidedge.co.nz

# DEPRECATED — no longer used for watch brief delivery.
# Watch briefs are now sent per-client using each user's registered email
# address and saved sector preferences (read from portal_config.json).
# This variable is kept for backward compatibility with the old scheduler.py
# but is not read by scheduler_railway.py or pursuit_worker.py.
# BRIEFING_RECIPIENTS=client1@company.com,client2@company.com

# ── Pipeline / Scheduler ──────────────────────────────────────────────────────
# Comma-separated client names for Layer 3 daily artefact generation.
L3_CLIENTS=Client One,Client Two

# Sector tags to filter the watchlist for Layer 3 (optional — blank = all sectors).
L3_SECTORS=infrastructure,FM

# Number of pursuit packages to generate per client per daily run.
L3_TOP=3

# Minimum composite score for a notice to receive Claude enrichment.
PRIORITY_THRESHOLD=4.0

# Score threshold for inclusion in the daily watchlist output.
WATCHLIST_THRESHOLD=3.5

# Maximum number of notices that receive Claude bidder-context enrichment per run.
MAX_ENRICHMENT_NOTICES=30

# Maximum notices in the daily watchlist.
TOP_N_WATCHLIST=25

# ── Output / Artefacts ────────────────────────────────────────────────────────
# Directory where pursuit packages, competitor profiles, and watch briefs are stored.
# On Railway, use a Railway Volume mounted at this path — otherwise files are lost
# on each redeploy (Railway containers are ephemeral).
ARTEFACTS_DIR=output/artefacts

# ── Layer 2 tuning ────────────────────────────────────────────────────────────
# Fuzzy match threshold for organisation name deduplication (0–100).
ORG_FUZZY_MATCH_THRESHOLD=88

# Days ahead to flag contracts approaching renewal.
RENEWAL_WINDOW_DAYS=90

# Days lookback for procurement surge detection.
SURGE_LOOKBACK_DAYS=30

# Max Claude agency profiles generated per Layer 2 run (cost control).
MAX_AGENCY_PROFILES_PER_RUN=15

# Max competitor assessments per Layer 2 run.
MAX_COMPETITOR_ASSESSMENTS=10

# ── Demo package branding ─────────────────────────────────────────────────────
# Used when generating cold-outreach sample pursuit packages.
DEMO_FIRM_NAME=BidEdge
DEMO_CONTACT_EMAIL=robert@bidedge.co.nz
DEMO_CONTACT_PHONE=+64 9 XXX XXXX
DEMO_WEBSITE=https://bidedge.co.nz

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
