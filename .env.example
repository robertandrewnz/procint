# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/procint"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# CLAUDE_MODEL=claude-sonnet-4-5          # override if needed
# CLAUDE_MODEL_L3=claude-sonnet-4-5       # Layer 3 longer-form synthesis

# ── Pipeline behaviour ────────────────────────────────────────────────────────
PRIORITY_THRESHOLD=5.0
WATCHLIST_THRESHOLD=4.0
TOP_N_WATCHLIST=25
MAX_ENRICHMENT_NOTICES=20
LOG_LEVEL=INFO

# ── Layer 2 ───────────────────────────────────────────────────────────────────
ORG_FUZZY_MATCH_THRESHOLD=88
RENEWAL_WINDOW_DAYS=90
SURGE_LOOKBACK_DAYS=30

# ── Layer 3 — Executive artefacts ─────────────────────────────────────────────
ARTEFACTS_DIR=output/artefacts

# Client portal
PORTAL_PASSWORD=your-shared-portal-password
PORTAL_SECRET_KEY=a-random-secret-key-for-flask-sessions
# PORTAL_HOST=0.0.0.0    # bind to all interfaces in production
# PORTAL_PORT=5000

# ── Scheduler — active clients ────────────────────────────────────────────────
# Comma-separated client names for Layer 3 daily artefact generation.
# These names are used to personalise pursuit packages and watch briefs.
L3_CLIENTS=Downer NZ,Fletcher Construction

# Sector filter for watch briefs (optional — leave blank for all sectors)
L3_SECTORS=infrastructure,FM

# Number of pursuit packages to generate per client per daily run
L3_TOP=3

# ── SMTP email — weekly brief and failure alerts ──────────────────────────────
# Required for: weekly watch brief delivery, failure alert emails.
# Gmail example: use an App Password (not your account password).
# Gmail App Passwords: myaccount.google.com → Security → App passwords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="Procurement Intelligence <your@gmail.com>"

# Comma-separated recipients for the Monday watch brief email
BRIEFING_RECIPIENTS=client1@company.com,client2@company.com

# Admin address for failure alert emails (defaults to first BRIEFING_RECIPIENT if blank)
ADMIN_EMAIL=your@gmail.com

# ── Demo package branding ─────────────────────────────────────────────────────
DEMO_FIRM_NAME="Procurement Win AI"
DEMO_CONTACT_EMAIL=your@email.com
DEMO_CONTACT_PHONE=+64 9 XXX XXXX
DEMO_WEBSITE=https://your-domain.com
