# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/procint"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# CLAUDE_MODEL=claude-sonnet-4-5          # override model if needed
# CLAUDE_MODEL_L3=claude-sonnet-4-5       # Layer 3 uses longer-form synthesis

# ── Pipeline behaviour ────────────────────────────────────────────────────────
PRIORITY_THRESHOLD=5.0
WATCHLIST_THRESHOLD=4.0
TOP_N_WATCHLIST=25
MAX_ENRICHMENT_NOTICES=20
LOG_LEVEL=INFO

# ── Layer 2 ───────────────────────────────────────────────────────────────────
ORG_FUZZY_MATCH_THRESHOLD=88
RENEWAL_WINDOW_DAYS=90
SURGE_LOOKBACK_DAYS=30

# ── Layer 3 — Executive artefacts ─────────────────────────────────────────────
ARTEFACTS_DIR=output/artefacts

# Client portal
PORTAL_PASSWORD=your-shared-portal-password
PORTAL_SECRET_KEY=a-random-secret-key-for-flask-sessions
# PORTAL_HOST=0.0.0.0    # bind to all interfaces in production
# PORTAL_PORT=5000

# Weekly briefing email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Procurement Intelligence <your@email.com>"
BRIEFING_RECIPIENTS=client1@company.com,client2@company.com

# Demo package branding (for cold-outreach samples)
DEMO_FIRM_NAME="Procurement Win AI"
DEMO_CONTACT_EMAIL=your@email.com
DEMO_CONTACT_PHONE=+64 9 XXX XXXX
DEMO_WEBSITE=https://your-domain.com
